# Example .env.local file for SMTP configuration
# Copy this file to .env.local and fill in your actual SMTP credentials.
# DO NOT commit your .env.local file to version control if it contains sensitive data.

# SMTP Server Settings for Nodemailer
SMTP_HOST=your_smtp_host.example.com
SMTP_PORT=587 # Or 465 if using SSL/TLS directly
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_SECURE=false # Set to true for port 465 (SSL/TLS), false for port 587 (STARTTLS)
SMTP_FROM_EMAIL=you@yourverifieddomain.com # The email address that will appear as the sender (must be verified with your SMTP provider)

# Email Recipient Settings
DESIGNATED_RECIPIENT_EMAIL=daniloiliccc@gmail.com # The email address where contact form messages will be sent

# For Resend (if you decide to switch back or use it for other purposes)
# RESEND_API_KEY=re_yourActualResendApiKey
# RESEND_FROM_EMAIL=you@yourverifieddomain.com
