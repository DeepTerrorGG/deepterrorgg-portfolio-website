# This is an example file.
# For your application to work, you need to create a .env.local file
# and fill it with your actual credentials.

# Resend API Key - Get this from your Resend dashboard
# IMPORTANT: This key should have 'Sending access' permissions.
RESEND_API_KEY=re_xxxxxxxx_xxxxxxxxxxxxxxxxxxxx

# Your Email Address - The address where you want to receive emails from the contact form.
DESIGNATED_RECIPIENT_EMAIL=your-email@example.com

# From Email Address - The email address that appears in the 'From' field.
# For testing with an unverified domain, you can use 'onboarding@resend.dev'.
# For production, this MUST be an email from a domain you have verified in Resend.
RESEND_FROM_EMAIL=onboarding@resend.dev
