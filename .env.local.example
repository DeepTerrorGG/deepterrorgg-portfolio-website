# Email Sending Configuration (Nodemailer with SMTP)
# =====================================================
# IMPORTANT: Replace the placeholder values below with your actual SMTP credentials.
# For Gmail, you'll need to generate an App Password if you have 2-Step Verification enabled.
# See: https://support.google.com/accounts/answer/185833

# SMTP Server Details
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465 # Use 465 for SSL/TLS (recommended for Gmail) or 587 for STARTTLS
SMTP_USER=YOUR_GMAIL_ADDRESS@gmail.com # e.g., deepterrorgg.portfolio@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD # The 16-character app password you generated

# SMTP Security
# Set to 'true' for SSL/TLS (typically with port 465).
# Set to 'false' for STARTTLS (typically with port 587).
SMTP_SECURE=true

# Email Addresses
SMTP_FROM_EMAIL=YOUR_GMAIL_ADDRESS@gmail.com # This should be the same as SMTP_USER for Gmail
DESIGNATED_RECIPIENT_EMAIL=daniloiliccc@gmail.com # The email address where contact form submissions will be sent

# NEXT_PUBLIC_BASE_URL=http://localhost:3000 # Optional: For constructing absolute URLs if needed
