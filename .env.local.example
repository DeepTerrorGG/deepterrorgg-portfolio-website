# Resend API Key - REQUIRED for sending emails
# Get your API key from your Resend dashboard (https://resend.com/api-keys)
# IMPORTANT: This MUST be a live, valid API key from Resend.
# Example: re_12345678_abcdefghijklmnopqrstuvwxyz
RESEND_API_KEY="YOUR_ACTUAL_RESEND_API_KEY"

# Email address where contact form submissions will be sent - OPTIONAL
# Defaults to daniloiliccc@gmail.com if not set
RECIPIENT_EMAIL="daniloiliccc@gmail.com"

# Email address used as the "from" address when sending emails - OPTIONAL
# Defaults to "Portfolio <onboarding@resend.dev>" if not set
# IMPORTANT: If you are using a LIVE (non-test) RESEND_API_KEY,
# this email address MUST be from a domain that you have verified in your Resend account.
# Using "onboarding@resend.dev" with a live key will likely result in delivery failures.
# Example: "Your Name <contact@yourverifieddomain.com>"
SENDING_EMAIL="Portfolio <onboarding@resend.dev>"
