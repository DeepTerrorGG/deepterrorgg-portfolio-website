rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public read access to kanban board, but write only if authenticated
    match /kanban-columns/{columnId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /kanban-columns/{columnId}/tasks/{taskId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
     match /kanban-categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow anyone to read discovered recipes
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can add new recipes
    }
    
    // Allow anyone to read whiteboard objects
    match /whiteboard-objects/{objectId} {
      allow read: if true;
      allow write: if request.auth != null; 
    }
  }
}
