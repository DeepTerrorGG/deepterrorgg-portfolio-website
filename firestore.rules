rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Players can only manage their own profile.
    match /players/{playerId} {
      allow read, write: if request.auth.uid == playerId;
    }
    
    // Allow any authenticated user to list the games collection to find waiting games.
    match /games {
      allow list: if request.auth != null;
    }

    // Game documents can be read by anyone, but only created by authenticated users
    // and modified by the players involved in that game.
    match /games/{gameId} {
      allow get: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.player1Id || request.auth.uid == resource.data.player2Id);
    }
  }
}
