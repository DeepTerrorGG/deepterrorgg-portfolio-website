
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
        return request.auth.uid == userId;
    }
    
    // For this demo, we'll use a simple "admin" claim. In a real app,
    // this would be managed securely via a backend.
    function isAdmin() {
        return request.auth.token.admin == true;
    }

    match /users/{userId}/{allSubcollections=**} {
      allow read, write: if true;
    }
    
    match /artworks/{artworkId} {
        allow read, write: if true;
    }
    
    match /about_me/{aboutMeId} {
        allow read, write: if true;
    }
    
    match /contact_info/{contactInfoId} {
        allow read, write: if true;
    }

    match /kanban-columns/{columnId} {
        allow read, write: if true;
    }

    match /kanban-columns/{columnId}/tasks/{taskId} {
        allow read, write: if true;
    }

    match /kanban-categories/{categoryId} {
        allow read, write: if true;
    }

    match /recipes/{recipeId} {
        allow read, write: if true;
    }

    match /timeCapsules/{capsuleId} {
      allow read, write: if true;
    }

    match /whiteboard-objects/{objectId} {
      allow read, write: if true;
    }

    match /content_types/{contentTypeId} {
        allow read, write: if true;
    }

    match /content_entries/{contentEntryId} {
        allow read, write: if true;
    }
    
    match /system_logs/{logId} {
      // Allow anyone to read the logs
      allow read: if true; 
      
      // ONLY allow users to CREATE new log entries.
      // They cannot update or delete existing logs.
      allow create: if request.resource.data.msg is string &&
                       request.resource.data.msg.size() < 500 &&
                       request.resource.data.level in ['info', 'warn', 'error'] &&
                       request.resource.data.timestamp == request.time;
      
      // Explicitly deny update and delete
      allow update, delete: if false;
    }
  }
}
