
{
  "entities": {
    "ChatSession": {
      "title": "Chat Session",
      "description": "Represents a single chat conversation.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "personality": {
          "type": "string",
          "enum": [
            "Default",
            "Helpful Assistant",
            "Snarky",
            "Pirate",
            "Poet",
            "Shakespearean",
            "Tech Bro",
            "Philosopher",
            "Flirty"
          ]
        },
        "messages": {
          "type": "array",
          "items": {
            "$ref": "#/entities/ChatMessage"
          }
        }
      },
      "required": [
        "id",
        "title",
        "createdAt",
        "messages",
        "personality"
      ]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Represents a single message within a chat session.",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "user",
            "model"
          ]
        },
        "content": {
          "type": "string"
        }
      },
      "required": [
        "role",
        "content"
      ]
    },
    "Artwork": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Artwork",
      "type": "object",
      "description": "Represents an artwork displayed on the portfolio.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Artwork entity."
        },
        "title": {
          "type": "string",
          "description": "Title of the artwork."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the artwork image.",
          "format": "uri"
        },
        "description": {
          "type": "string",
          "description": "Description of the artwork."
        },
        "displayOrder": {
          "type": "number",
          "description": "The order in which the artwork is displayed."
        }
      },
      "required": [
        "id",
        "title",
        "imageUrl",
        "description",
        "displayOrder"
      ]
    },
    "AboutMe": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AboutMe",
      "type": "object",
      "description": "Stores information for the 'About Me' section of the portfolio.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AboutMe entity."
        },
        "content": {
          "type": "string",
          "description": "The main text content for the 'About Me' section. HTML or plain text."
        }
      },
      "required": [
        "id",
        "content"
      ]
    },
    "ContactInfo": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ContactInfo",
      "type": "object",
      "description": "Stores contact information displayed on the 'Contact' section.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ContactInfo entity."
        },
        "email": {
          "type": "string",
          "description": "Email address for contact.",
          "format": "email"
        },
        "linkedInUrl": {
          "type": "string",
          "description": "URL of the LinkedIn profile.",
          "format": "uri"
        },
        "githubUrl": {
          "type": "string",
          "description": "URL of the Github profile.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "email",
        "linkedInUrl",
        "githubUrl"
      ]
    },
    "Recipe": {
      "title": "Crafting Recipe",
      "description": "Represents a discovered crafting recipe in the AI Infinity Craft game.",
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "A unique, sorted key for the recipe combination, e.g., 'earth+fire'."
        },
        "item1": {
          "type": "string",
          "description": "The first item in the combination."
        },
        "item2": {
          "type": "string",
          "description": "The second item in the combination."
        },
        "result": {
          "type": "string",
          "description": "The resulting item."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the recipe was first discovered."
        }
      },
      "required": ["key", "item1", "item2", "result", "createdAt"]
    },
    "TimeCapsule": {
      "title": "Time Capsule",
      "description": "A secure, time-locked message capsule.",
      "type": "object",
      "properties": {
        "encryptedMessage": {
          "type": "string",
          "description": "The message, encrypted client-side."
        },
        "unlockDate": {
          "type": "string",
          "format": "date-time",
          "description": "The future date when the message can be decrypted."
        }
      },
      "required": ["encryptedMessage", "unlockDate"]
    },
    "ContentType": {
        "title": "Content Type",
        "description": "Defines the schema for a type of content in the CMS.",
        "type": "object",
        "properties": {
            "name": { "type": "string", "description": "Display name, e.g., 'Blog Post'" },
            "slug": { "type": "string", "description": "API-friendly slug, e.g., 'blog-post'" },
            "fields": {
                "type": "array",
                "items": { "$ref": "#/entities/Field" }
            }
        },
        "required": ["name", "slug", "fields"]
    },
    "Field": {
        "title": "Field",
        "description": "A single field within a Content Type schema.",
        "type": "object",
        "properties": {
            "name": { "type": "string" },
            "type": { "type": "string", "enum": ["text", "textarea", "number", "boolean", "date", "image"] }
        },
        "required": ["name", "type"]
    },
    "ContentEntry": {
        "title": "Content Entry",
        "description": "An individual piece of content, based on a Content Type.",
        "type": "object",
        "properties": {
            "contentTypeId": { "type": "string" },
            "slug": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" },
            "updatedAt": { "type": "string", "format": "date-time" },
            "fields": {
                "type": "object",
                "description": "A map where keys are field names and values are the content.",
                "additionalProperties": true
            }
        },
        "required": ["contentTypeId", "slug", "createdAt", "updatedAt", "fields"]
    },
     "FractalJob": {
      "title": "Fractal Job",
      "description": "A single tile of the fractal to be rendered by a worker.",
      "type": "object",
      "properties": {
        "tileX": { "type": "number" },
        "tileY": { "type": "number" },
        "zoom": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "claimed", "completed"] },
        "claimedBy": { "type": "string" },
        "claimedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tileX", "tileY", "zoom", "status"]
    },
    "FractalTile": {
      "title": "Fractal Tile",
      "description": "The rendered image data for a completed fractal job.",
      "type": "object",
      "properties": {
        "tileId": { "type": "string" },
        "imageData": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tileId", "imageData", "createdAt"]
    },
    "FractalWorkerProfile": {
      "title": "Fractal Worker Profile",
      "description": "Stores profile information for a distributed fractal rendering worker.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The worker's unique ID." },
        "displayName": { "type": "string", "description": "The chosen display name for the worker." },
        "tilesCompleted": { "type": "number", "description": "The total number of fractal tiles rendered by this worker." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "tilesCompleted", "createdAt"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/ChatSession"
      },
      "description": "Stores individual chat sessions."
    },
    "/artworks/{artworkId}": {
      "schema": {
        "$ref": "#/entities/Artwork"
      },
      "description": "Stores artwork information."
    },
    "/about_me/{aboutMeId}": {
      "schema": {
        "$ref": "#/entities/AboutMe"
      },
      "description": "Stores 'About Me' information."
    },
    "/contact_info/{contactInfoId}": {
      "schema": {
        "$ref": "#/entities/ContactInfo"
      },
      "description": "Stores contact information."
    },
    "/recipes/{recipeId}": {
      "schema": {
        "$ref": "#/entities/Recipe"
      },
      "description": "Stores discovered crafting recipes for the AI Infinity Craft game."
    },
    "/timeCapsules/{capsuleId}": {
      "schema": {
        "$ref": "#/entities/TimeCapsule"
      },
      "description": "Stores encrypted time capsules."
    },
    "/content_types/{contentTypeId}": {
      "schema": {
        "$ref": "#/entities/ContentType"
      },
      "description": "Defines the schemas for different types of content."
    },
    "/content_entries/{contentEntryId}": {
      "schema": {
        "$ref": "#/entities/ContentEntry"
      },
      "description": "Stores the actual content entries for the CMS."
    },
     "/fractal-jobs/{jobId}": {
      "schema": { "$ref": "#/entities/FractalJob" },
      "description": "Job queue for distributed fractal rendering."
    },
    "/fractal-tiles/{tileId}": {
      "schema": { "$ref": "#/entities/FractalTile" },
      "description": "Storage for completed fractal image tiles."
    },
    "/fractal-workers/{workerId}": {
      "schema": { "$ref": "#/entities/FractalWorkerProfile" },
      "description": "Profiles for the fractal rendering leaderboard."
    }
  }
}
