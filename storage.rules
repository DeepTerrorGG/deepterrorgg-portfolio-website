rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all files, but only authenticated users can write.
    // In a real app, you'd want more granular control, e.g., only allowing
    // users to write to their own folder.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
